{
    "layer": "bottom",
    "position": "bottom",
    "spacing": 4,
    "modules-left": [ "sway/workspaces", "sway/scratchpad", "sway/mode" ],
    "modules-center": ["sway/window"],
    "modules-right": [
        "tray",
		"clock",
        "network",
        "backlight",
        "pulseaudio",
        "cpu",
        "memory",
        "battery",
        "custom/power-button"
    ],
    "custom/separator": {
        "format": "Όακ",
        "tooltip": false
    },
    "cpu": {
        "format": "{usage}% ΎΜδ",
        "tooltip": true,
        "on-click": "wezterm -e btop"
    },
    "memory": {
        "format": "{}% ΎΔΚ",
        "on-click": "wezterm -e btop",
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "ΎΜΤ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "custom/drun": {
        "format": "<span size=\"10pt\">ΎΑ║</span>",
        "tooltip": false,
        "on-click": "wofi --conf=$HOME/.config/wofi/launch"
    },
    "custom/power-button": {
        "format": "ΎΑΣ",
        "tooltip": false,
        "on-click": "swaynag -t warning -m 'Shutdown?' -B 'Yes' 'systemctl poweroff'"
    },
    "sway/workspaces": {
        "disable-scroll": true
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "max-length": 50,
        "tooltip": true
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{signalStrength}% ΎΘτ",
        "format-ethernet": "{ipaddr}/{cidr} ≤░ΙΒ",
        "tooltip-format": "{ifname} via {gwaddr} ≤░ΙΒ",
        "tooltip-format-disconnected": "Disconnected",
        "format-linked": "{ifname} (No IP) ≤░ΙΒ",
        "format-disconnected": "ΎΘτ",
        "format-alt": "{essid} {signalStrength}% ΎΘτ"
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ≤▒ΡΜ",
        "format-plugged": "{capacity}% ΎΘο",
        // "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "tooltip": true,
        "tooltip-format": "{time}",
        "tooltip-format-discharging": "{capacity}% | {time}"
    },
    "clock": {
        "format": "{:%H:%M} ΎΑΩ",
        "format-alt": "{:%a %Y-%m-%d} ΎΕ│",
        "tooltip": true,
        "tooltip-format": "{:%a %Y-%m-%d} ΎΕ│"
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "Όυν",
        "format-icons": {
            "headphone": "ΎΑξ",
            "default": ["ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol",
        "tooltip-format": "{volume}% | {desc}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["ΎΗΖ", "ΎΕΣ"]
    },
    "tray": {
        "icon-size": 15,
        "spacing": 6,
    }
}
