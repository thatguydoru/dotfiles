{
    "layer": "top",
    "position": "top",
    "spacing": 4,
    "modules-left": [ "sway/workspaces", "tray", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": [
        "network",
        "backlight",
        "pulseaudio",
        "battery",
        "clock",
        "custom/power-button",
    ],
    "custom/drun": {
        "format": "<span size=\"10pt\">ΎΑ║</span>",
       "tooltip": false,
        "on-click": "wofi --show=drun",
    },
    "custom/power-button": {
        "format": "ΎΑΣ",
        "tooltip": false,
        // "on-click": "systemctl poweroff",
        "on-click": "swaynag -t warning -m 'Shutdown?' -B 'Yes' 'systemctl poweroff'"
    },
    "sway/workspaces": {
        "disable-scroll": true,
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "max-length": 50,
        "tooltip": true,
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "ΎΘτ",
        "format-ethernet": "{ipaddr}/{cidr} ≤░ΙΒ",
        "tooltip-format": "{ifname} via {gwaddr} ≤░ΙΒ",
        "tooltip-format-disconnected": "Disconnected",
        "format-linked": "{ifname} (No IP) ≤░ΙΒ",
        "format-disconnected": "ΎΘτ",
        "format-alt": "{essid} {signalStrength}% ΎΘτ"
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ≤▒ΡΜ",
        "format-plugged": "{capacity}% ΎΘο",
        // "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "tooltip": true,
        "tooltip-format": "{time}",
        "on-click": "kitty btop",
        "tooltip-format-discharging": "{capacity}% | {time}",
    },
    "clock": {
        "format": "{:%H:%M} ΎΑΩ",
            "format-alt": "{:%a %Y-%m-%d} ΎΕ│"
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "Όυν",
        "format-icons": {
            "headphone": "ΎΑξ",
            "default": ["ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol",
        "tooltip-format": "{volume}% | {desc}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["ΎΗΖ", "ΎΕΣ"],
    },
    "tray": {
            "icon-size": 15,
            "spacing": 6,
    },
}
