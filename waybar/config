{
    "layer": "top",
    "position": "top",
    "spacing": 4,
    "modules-left": ["custom/separator-backward", "sway/workspaces", "custom/separator-backward", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": [
    	"custom/separator-forward", 
    	"network", 
    	"backlight", 
    	"pulseaudio", 
        "battery", 
        "clock", 
        "custom/separator-forward"
    ],

    "custom/separator-forward": {
	"format": "/",
	"tooltip": false
    },
    "custom/separator-backward": {
	"format": "\\",
	"tooltip": false,
    },
    "sway/workspaces": {
        "disable-scroll": true,
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
	"max-length": 50,
	"tooltip": true,
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "",
        "format-ethernet": "{ipaddr}/{cidr} ",
        "tooltip-format": "{ifname} via {gwaddr} ",
	"tooltip-format-disconnected": "Disconnected",
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "",
        "format-alt": "{essid} {signalStrength}% "
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        // "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["", "", "", "", ""],
        "tooltip": true,
        "tooltip-format": "{time}", 
        "on-click": "alacritty -e btop",
        "tooltip-format-discharging": "{capacity}% | {time}",
    },
    "clock": {
        "format": "{:%H:%M} ",
            "format-alt": "{:%a %Y-%m-%d} "
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "",
        "format-icons": {
            "headphone": "",
            "default": ["", ""]
        },
        "on-click": "alacritty -e alsamixer",
        "tooltip-format": "{volume}% | {desc}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["", ""],
    }
}
