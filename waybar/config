{
    "layer": "top",
    "position": "top",
    "spacing": 2,
    "modules-left": ["custom/separator-backward", "sway/workspaces", "custom/separator-backward", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": [
    	"custom/separator-forward", 
    	"network", 
	"custom/separator-forward", 
    	"backlight", 
	"custom/separator-forward", 
    	"pulseaudio", 
	"custom/separator-forward", 
	"battery", 
	"custom/separator-forward",
	"clock", 
	"custom/separator-forward"
    ],

    "custom/separator-forward": {
	"format": "/",
	"tooltip": false
    },
    "custom/separator-backward": {
	"format": "\\",
	"tooltip": false,
    },
    "sway/workspaces": {
        "disable-scroll": true,
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
	"max-length": 50,
	"tooltip": true,
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "",
        "format-ethernet": "{ipaddr}/{cidr} ",
        "tooltip-format": "{ifname} via {gwaddr} ",
	"tooltip-format-disconnected": "Disconnected",
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "",
        "format-alt": "{essid} {signalStrength}% "
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        // "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["", "", "", "", ""],
	"tooltip": true,
	"tooltip-format": "{time}" 
    },
    "clock": {
	"format": "{:%H:%M} ",
        "format-alt": "{:%a %Y-%m-%d} "
    },
    "pulseaudio": {
	"format": "{volume}% {icon}",
	"format-muted": "",
	"format-icons": {
        "headphone": "",
        "default": ["", ""]
	},
	"on-click": "alacritty -e alsamixer"
    },
    "backlight": {
	"device": "intel_backlight",
	"format": "{percent}% {icon}",
	"format-icons": ["", ""]
    }
}
